#!/usr/bin/env python3
"""
sint-tmux — tmux status bar script for SINT memory.

Add to .tmux.conf:
  set -g status-right "#(python3 /home/lain/.opencode/bin/sint-tmux)"

Or for right side with colors:
  set -g status-right-length 60
  set -g status-right "#[fg=green]#(python3 /home/lain/.opencode/bin/sint-tmux)#[default]"
"""

import json
from pathlib import Path

MEMORY_DIR = Path("/home/lain/.opencode/memory")
STATE_FILE = MEMORY_DIR / "state.json"
CHAIN_FILE = MEMORY_DIR / "chain.jsonl"
BLOCKS_DIR = MEMORY_DIR / "blocks"


def main():
    try:
        # Get focus
        if STATE_FILE.exists():
            state = json.loads(STATE_FILE.read_text())
            focus = state.get("focus", [])
            if focus:
                project = focus[0].get("project", "?")
                task = focus[0].get("task", "")[:20]
                focus_str = f"SINT: {project}"
            else:
                focus_str = "SINT: idle"
        else:
            focus_str = "SINT: no state"

        # Get chain length
        if CHAIN_FILE.exists():
            lines = CHAIN_FILE.read_text().strip().split("\n")
            chain_len = len([l for l in lines if l.strip()])
        else:
            chain_len = 0

        # Get block count
        blocks = list(BLOCKS_DIR.glob("*.json")) if BLOCKS_DIR.exists() else []
        block_count = len(blocks)

        # Output for tmux (keep short)
        print(f"{focus_str} | {block_count} blocks | chain:{chain_len}")

    except Exception:
        print("SINT: error")


if __name__ == "__main__":
    main()
